# Node Backend — Unraid Template
# Copier ce fichier en .env et ajuster les valeurs

# ── Chemin des données ────────────────────────────────────────────────────────
APP_DATA_PATH=/mnt/user/appdata/node-backend

# ── Version de l'image ────────────────────────────────────────────────────────
APP_VERSION=latest

# ── Serveur ───────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_PORT=3000
